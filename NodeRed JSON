        "type": "function",
        "z": "06d68578bb544e93",
        "name": "Data Storage and transfer ",
        "func": "const parts = msg.topic.split(\"/\");\nconst type = parts[0];        // \"joint\" or \"imu\"\nconst data = parts[1];\n\nlet finger, label;\n                   \n// determine source\nif (type === \"joint\") {\n    [finger, label] = data.split(\"_\");   // POINTER, MCP\n}\nelse if (type === \"abduction\") {\n    finger = data;\n    label = \"ABD\";   // name for IMU line\n}\nelse {\n    return null;\n}\n\n// filter by selected finger\nconst selected = flow.get('selectedfinger') || \"POINTER\";\nif (finger !== selected) return null;\n\n// convert value\nconst val = Number(msg.payload);\nif (isNaN(val)) return null;\n\n// time handling (linear seconds)\nlet timer = flow.get('Tstart_global');\nif (!timer) {\n    timer = Date.now();\n    flow.set('Tstart_global', timer);\n}\n\nconst t = (Date.now() - timer) / 1000;\n\n// send to chart\nmsg.topic = label;   // MCP, PIP, DIP, ABD\nmsg.payload = {\n    x: t,\n    y: val\n};\n\nreturn msg\n\n",
